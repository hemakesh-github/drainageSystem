# Copy to .env and adjust, or run: npm run set-local-api

# Local dev (PC on Wi‑Fi — phone must be on same network; uvicorn --host 0.0.0.0 --port 8000)
# EXPO_PUBLIC_API_URL=http://192.168.0.104:8000

# Android emulator → host machine
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Production (Render or other HTTPS API — no trailing slash)
# EXPO_PUBLIC_API_URL=https://your-service-name.onrender.com

EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:8000
